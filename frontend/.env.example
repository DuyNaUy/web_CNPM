# Frontend Environment Variables
# Copy file này thành .env.local và điền các giá trị thực tế

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_TIMEOUT=30000

# Optional: Analytics
